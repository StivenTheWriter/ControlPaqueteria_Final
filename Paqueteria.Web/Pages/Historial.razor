@page "/historial"
@using Paqueteria.Business.DTOs
@inject HttpClient Http

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Historial de <span class="text-success">Entregas</span></h2>

    <div class="card border-0 shadow-sm overflow-hidden">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light">
                <tr>
                    <th>FECHA ENTREGA</th>
                    <th>TRACKING</th>
                    <th>RESIDENTE</th>
                    <th>COURIER</th>
                    <th>ESTADO</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in listaEntregados)
                {
                    <tr>
                        <td>@DateTime.Now.ToShortDateString()</td>
                        <td class="fw-bold">@p.TrackingCode</td>
                        <td>@p.NombreResidente</td>
                        <td>@p.Courier</td>
                        <td><span class="badge bg-success">Completado</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    List<PaqueteDto> listaEntregados = new();

    protected override async Task OnInitializedAsync()
    {
        var todos = await Http.GetFromJsonAsync<List<PaqueteDto>>("api/paquetes") ?? new();
        listaEntregados = todos.Where(p => p.Estado == "Entregado").ToList();
    }
}