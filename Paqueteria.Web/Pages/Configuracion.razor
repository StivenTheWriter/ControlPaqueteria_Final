@page "/configuracion"

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Configuración de <span class="text-primary">Codex</span></h2>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">Datos del Edificio</h5>
                <div class="mb-3">
                    <label class="form-label text-muted small">Nombre de la Torre</label>
                    <input class="form-control bg-light" value="Torre Corporativa Santo Domingo" />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small">Dirección</label>
                    <input class="form-control bg-light" value="Av. Abraham Lincoln #123" />
                </div>
                <button class="btn btn-primary btn-sm">Actualizar Perfil</button>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3">Preferencias de Sistema</h5>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-switch" type="checkbox" checked />
                    <label class="form-check-label">Notificaciones por Email</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-switch" type="checkbox" checked />
                    <label class="form-check-label">Modo Oscuro Automático</label>
                </div>
                <hr>
                <small class="text-muted">Versión de Codex: 1.0.4-stable</small>
            </div>
        </div>
    </div>
</div>