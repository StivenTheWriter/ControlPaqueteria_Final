@page "/"
@using Paqueteria.Business.DTOs
@using Paqueteria.Domain.Entities
@inject HttpClient Http

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 15px;
        transition: transform 0.3s ease;
    }
    .glass-card:hover { transform: translateY(-5px); }
    .hero-gradient {
        background: linear-gradient(135deg, #0d6efd 0%, #002d72 100%);
        border-radius: 20px;
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="hero-gradient p-5 text-white mb-5 shadow-lg position-relative">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold">Codex <span class="text-info">OS</span></h1>
                <p class="lead opacity-75">Plataforma de Control Logístico y Recepción Residencial.</p>
                <div class="mt-4">
                    <button class="btn btn-info btn-lg px-4 fw-bold me-2">Nueva Recepción</button>
                    <button class="btn btn-outline-light btn-lg px-4">Ver Reportes</button>
                </div>
            </div>
            <div class="col-lg-4 d-none d-lg-block text-end">
                <i class="bi bi-shield-check" style="font-size: 120px; opacity: 0.2;"></i>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="glass-card p-4 shadow-sm text-center">
                <div class="text-primary mb-2"><i class="bi bi-people-fill fs-2"></i></div>
                <h3 class="fw-bold m-0">@totalResidentes</h3>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Residentes</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 shadow-sm text-center border-bottom border-warning border-4">
                <div class="text-warning mb-2"><i class="bi bi-box-seam fs-2"></i></div>
                <h3 class="fw-bold m-0">@paquetesPendientes</h3>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">En Almacén</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 shadow-sm text-center border-bottom border-success border-4">
                <div class="text-success mb-2"><i class="bi bi-check-circle fs-2"></i></div>
                <h3 class="fw-bold m-0">@paquetesEntregados</h3>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Entregados hoy</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 shadow-sm text-center">
                <div class="text-info mb-2"><i class="bi bi-graph-up fs-2"></i></div>
                <h3 class="fw-bold m-0">98%</h3>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Eficiencia</small>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="glass-card p-4 shadow-sm">
                <h5 class="fw-bold mb-4 border-bottom pb-2">Actividad Reciente</h5>
                @if(paquetesRecientes.Count == 0) {
                    <p class="text-muted">No hay movimientos registrados hoy.</p>
                } else {
                    @foreach(var p in paquetesRecientes.Take(5)) {
                        <div class="d-flex align-items-center mb-3 p-2 bg-light rounded">
                            <div class="bg-primary text-white p-2 rounded-circle me-3"><i class="bi bi-box"></i></div>
                            <div class="flex-grow-1">
                                <h6 class="m-0 fw-bold">@p.TrackingCode</h6>
                                <small class="text-muted">Asignado a: @p.NombreResidente</small>
                            </div>
                            <span class="badge bg-soft-warning text-warning">@p.Estado</span>
                        </div>
                    }
                }
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-4 shadow-sm bg-dark text-white">
                <h5 class="fw-bold mb-3">Soporte Codex</h5>
                <p class="small opacity-75">¿Necesitas ayuda con la plataforma? Contacta con nuestro equipo técnico.</p>
                <hr class="opacity-25">
                <div class="d-grid">
                    <button class="btn btn-outline-info btn-sm">Abrir Ticket</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    int totalResidentes = 0;
    int paquetesPendientes = 0;
    int paquetesEntregados = 0;
    List<PaqueteDto> paquetesRecientes = new();

    protected override async Task OnInitializedAsync() {
        var residentes = await Http.GetFromJsonAsync<List<Residente>>("api/residentes") ?? new();
        paquetesRecientes = await Http.GetFromJsonAsync<List<PaqueteDto>>("api/paquetes") ?? new();

        totalResidentes = residentes.Count;
        paquetesPendientes = paquetesRecientes.Count(p => p.Estado == "Pendiente");
        paquetesEntregados = paquetesRecientes.Count(p => p.Estado == "Entregado");
    }
}